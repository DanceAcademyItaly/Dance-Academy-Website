---
interface Props {
  initialIndex?: number;
}
const { initialIndex = 0 } = Astro.props;

const images = [
  '/assets/bg/1.jpg',
  '/assets/bg/2.jpg',
  '/assets/bg/3.jpg',
  '/assets/bg/4.jpg',
  '/assets/bg/5.jpg',
  '/assets/bg/6.jpg',
];
---
<div class="image-bg" id="image-bg" data-initial={initialIndex}>
  {images.map((src, i) => (
    <img src={src} class="bg-slide" data-index={i} alt="" aria-hidden="true" />
  ))}
</div>
