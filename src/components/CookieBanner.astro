<div id="cookieBanner" class="cookie-bar" role="dialog" aria-label="Preferenze cookie" aria-modal="true">
  <div class="cookie-bar-row">
    <p class="cookie-bar-text">
      Usiamo cookie YouTube per i video.
      <a href="/cookie">Cookie Policy</a>
    </p>
    <div class="cookie-bar-actions">
      <button id="cookieReject"      class="cookie-btn">Rifiuta</button>
      <button id="cookieAccept"      class="cookie-btn cookie-btn-primary">Accetta</button>
      <button id="cookieBannerClose" class="cookie-close" aria-label="Rifiuta e chiudi">✕</button>
    </div>
  </div>
</div>

<script>
  import { acceptAll, rejectAll, hasConsented } from '../scripts/consent';

  const banner = document.getElementById('cookieBanner') as HTMLElement;

  if (hasConsented()) {
    banner.style.display = 'none';
  } else {
    banner.style.display = 'flex';
  }

  function closeBanner() {
    banner.style.opacity = '0';
    setTimeout(() => { banner.style.display = 'none'; }, 250);
  }

  document.getElementById('cookieAccept')?.addEventListener('click', () => { acceptAll(); closeBanner(); });
  document.getElementById('cookieReject')?.addEventListener('click', () => { rejectAll(); closeBanner(); });
  document.getElementById('cookieBannerClose')?.addEventListener('click', () => { rejectAll(); closeBanner(); });

  window.DA_SHOW_BANNER = () => {
    localStorage.removeItem('da_cookie_consent');
    banner.style.opacity = '1';
    banner.style.display = 'flex';
  };

  window.DA_ACCEPT_ALL = () => {
    acceptAll();
    closeBanner();
  };
</script>

<style>
