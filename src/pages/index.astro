---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import ImageBackground from '../components/ImageBackground.astro';
import Hero from '../components/Hero.astro';
import siteData from '../content/site.json';
---
<Base
  title={siteData.title}
  description="Dance Academy Italy – Il format che racconta le scuole di danza italiane."
  ogTitle={siteData.title}
  ogImage="https://img.youtube.com/vi/L_cHp3yYADI/maxresdefault.jpg"
  ogUrl="https://www.dance-academy.it"
>
  <ImageBackground />
  <Header />
  <main>
    <Hero subtitle={siteData.hero.subtitle} />
  </main>
</Base>
